# Frontend (used by Vite in development if you need an explicit API base URL)
# Leave empty to use same-origin `/api` with Vite proxy.
VITE_API_BASE_URL=

# Backend server config
SERVER_PORT=8787
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:8081,http://localhost:5173

# Twilio WhatsApp credentials
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_WHATSAPP_TO=whatsapp:+971000000000
